# ── Supabase ──
# Copy this file to .env.local and fill in the values from your Supabase project
# (Flomatic account → Timion Intranet project → Settings → API).
#
# Both variables are safe to expose to the browser. Access control is enforced
# server-side by Supabase Row Level Security policies.
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"
